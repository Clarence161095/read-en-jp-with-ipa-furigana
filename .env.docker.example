# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# Database — path inside the container (mounted as named volume db_data:/app/db)
DATABASE_URL=file:/app/db/app.db

# NextAuth — NEXTAUTH_SECRET must be at least 32 random characters
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-to-a-random-string-at-least-32-chars

# Public URL of your app (use your EC2 public IP or domain)
NEXTAUTH_URL=http://YOUR-EC2-PUBLIC-IP:5678

# Admin account created automatically on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-secure-password
ADMIN_EMAIL=admin@example.com
